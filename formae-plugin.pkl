/*
 * Formae Plugin Manifest
 *
 * This file defines metadata for your Formae plugin.
 * Update the values below to match your plugin.
 */

// TODO: Change to your plugin name (lowercase, letters/numbers/hyphens)
name = "cloudflare"

// TODO: Update version following semver
version = "0.1.0"

// TODO: Resource type namespace prefix (uppercase)
// This appears in resource types: CLOUDFLARE::Service::Resource
namespace = "CLOUDFLARE"

// TODO: Describe what your plugin does
description = "Cloudflare resource plugin for Formae - manage DNS zones, records, and email routing"

// TODO: Your license (SPDX identifier)
license = "Apache-2.0"

// TODO: Minimum formae version required
minFormaeVersion = "0.80.1"

output {
  renderer = new JsonRenderer {}
}
