module dnsRecord

import "@formae/formae.pkl"
import "../cloudflare.pkl"
import "zone.pkl" as zone

const type = "Cloudflare::DNS::Record"

/// DNS record types supported by Cloudflare
typealias RecordType = "A" |        // IPv4 address
  "AAAA" |                          // IPv6 address
  "CNAME" |                         // Canonical name (alias)
  "TXT" |                           // Text record
  "MX" |                            // Mail exchange
  "NS" |                            // Name server
  "SRV" |                           // Service locator
  "CAA" |                           // Certificate Authority Authorization
  "PTR" |                           // Pointer record
  "SPF" |                           // Sender Policy Framework (deprecated, use TXT)
  "HTTPS" |                         // HTTPS service binding
  "SVCB"                            // Service binding

/// Resolvable reference to a Record resource
open class RecordResolvable extends formae.Resolvable {
  hidden type = module.type

  /// The record ID
  hidden id: RecordResolvable = (this) {
    property = "id"
  }

  /// The record name
  hidden name: RecordResolvable = (this) {
    property = "name"
  }

  /// The record content/value
  hidden content: RecordResolvable = (this) {
    property = "content"
  }
}

/// Cloudflare DNS Record
/// Individual DNS record within a zone.
/// Create: POST /zones/{zone_id}/dns_records
/// Read: GET /zones/{zone_id}/dns_records/{record_id}
/// Update: PATCH /zones/{zone_id}/dns_records/{record_id}
/// Delete: DELETE /zones/{zone_id}/dns_records/{record_id}
@cloudflare.ResourceHint {
  type = module.type
  identifier = "id"
}
open class Record extends formae.Resource {
  // ========== Required Properties ==========

  /// Zone ID this record belongs to (can be a resolvable reference)
  @cloudflare.FieldHint {
    required = true
    createOnly = true
  }
  zone_id: (String|zone.ZoneResolvable)

  /// DNS record name (e.g., "www", "@" for root, or full FQDN)
  @cloudflare.FieldHint { required = true }
  name: String

  /// Record type (A, AAAA, CNAME, MX, TXT, etc.)
  @cloudflare.FieldHint {
    required = true
    createOnly = true
  }
  `type`: RecordType

  /// Record content/value
  /// For A: IPv4 address
  /// For AAAA: IPv6 address
  /// For CNAME: target domain
  /// For MX: mail server hostname
  /// For TXT: text value
  @cloudflare.FieldHint { required = true }
  content: String

  // ========== Optional Properties ==========

  /// Time to live (TTL) in seconds
  /// 1 = automatic (Cloudflare will choose optimal TTL)
  /// Otherwise must be between 60 and 86400
  @cloudflare.FieldHint {}
  ttl: Int = 1

  /// Whether the record is proxied through Cloudflare
  /// Only applies to A, AAAA, and CNAME records
  @cloudflare.FieldHint {}
  proxied: Boolean?

  /// Priority for MX, SRV, and URI records
  /// Lower values have higher priority
  @cloudflare.FieldHint {}
  priority: Int?

  /// Comment/description for the record
  @cloudflare.FieldHint {}
  comment: String?

  /// Custom tags for the record
  @cloudflare.FieldHint {}
  tags: Listing<String>?

  // ========== Read-Only Properties (populated by Cloudflare, not managed) ==========

  /// Record ID (assigned by Cloudflare)
  id: String?

  /// Whether this record can be proxied
  proxiable: Boolean?

  /// Indicates the record was auto-created by Cloudflare
  locked: Boolean?

  /// Record creation timestamp
  created_on: String?

  /// Record modification timestamp
  modified_on: String?

  local parent = this

  /// Provides resolvable references to this record's properties
  hidden res: RecordResolvable = new {
    label = parent.label
    stack = parent.stack?.label
  }
}
